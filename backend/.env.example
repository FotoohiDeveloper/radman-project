# =============================================
# Backend & Ingestion Service Environment Variables
# کپی این فایل به .env و مقادیر واقعی رو پر کن
# =============================================

# --- JWT ---
JWT_SECRET_KEY=your_very_long_and_random_jwt_secret_here

# --- SMS.ir ---
SMSIR_API_KEY=your_smsir_api_key
SMSIR_OTP_TEMPLATE=your_template_id

# --- Finnotech ---
FINNOTECH_CLIENT_ID=your_client_id
FINNOTECH_CLIENT_SECRET=your_client_secret
FINNOTECH_NID=your_national_id
FINNOTECH_TOKEN_URL=https://apibeta.finnotech.ir/dev/v2/oauth2/token
FINNOTECH_BASE_URL=https://api.finnotech.ir

# --- Zohal ---
ZOHAL_API_TOKEN=your_zohal_api_token

# --- ArvanCloud S3 ---
ARVAN_S3_ACCESS_KEY=your_s3_access_key
ARVAN_S3_SECRET_KEY=your_s3_secret_key
ARVAN_S3_BUCKET_NAME=your_bucket_name
ARVAN_S3_REGION=ir-thr-at1
ARVAN_S3_ENDPOINT=https://your-bucket.s3.ir-thr-at1.arvanstorage.ir

# --- App ---
CORS_ALLOWED_ORIGIN=https://auth.hapagate.ir
APP_PORT=3000
APP_LANG=en
